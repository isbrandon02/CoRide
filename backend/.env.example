# Required in production — generate a long random string
SECRET_KEY=change-me

# JWT lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# SQLite by default; use e.g. postgresql+psycopg://user:pass@localhost/coride for Postgres
# Stored under backend/data/ when relative (see app/database.py).
DATABASE_URL=sqlite:///./data/coride.db

# Insert demo users from data/demo_accounts.json when the API starts (idempotent). Disable in production.
SEED_DEMO_ACCOUNTS=true
