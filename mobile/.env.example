# Backend base URL (no trailing slash). Optional if defaults work for your setup.
# iOS Simulator: defaults to http://127.0.0.1:8000
# Android Emulator: defaults to http://10.0.2.2:8000 (do not use 127.0.0.1)
# Physical device (Expo Go): REQUIRED — use your computer's LAN IP, same Wi‑Fi:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
# After changing .env, stop Expo (Ctrl+C) and run `npx expo start` again.
# EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Google Maps Platform key used for route previews and address verification.
# Enable Maps Static API, Routes API, and Geocoding API on the same project.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here
